# Environment Variables - Plantilla de ejemplo
# Copia este archivo a .env y configura los valores según tu entorno

# API Base URL
# Desarrollo local: http://localhost:8080/api
# Producción: https://erm.comware.com.ec/api
VITE_API_BASE_URL=http://localhost:8080/api

# Application Name
VITE_APP_NAME=Sistema de Gestión de Riesgos

# Environment (development | production)
VITE_ENV=development
